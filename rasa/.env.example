# ============================================================
# InfyBot v3 — Rasa Action Server Environment Variables
#
# Copy this file to  rasa/.env  and fill in your values.
# Load it before starting the action server:
#
#   source rasa/.env          (Linux / macOS — bash/zsh)
#   Get-Content rasa\.env | ForEach-Object { ... }  (Windows PowerShell)
#
# OR set these as system/shell environment variables directly.
# ============================================================

# ── MySQL connection (must match backend/.env) ───────────────
RASA_DB_HOST=localhost
RASA_DB_PORT=3306
RASA_DB_USER=root
RASA_DB_PASSWORD=your_mysql_password     # ← REQUIRED: change this
RASA_DB_NAME=infybot_db
