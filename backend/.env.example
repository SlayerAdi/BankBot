# ── Server ──────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── MySQL (local, no Docker) ─────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=infybot_db

# ── JWT ──────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_string_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Rasa (local) ─────────────────────
RASA_URL=http://localhost:5005

# Optional: absolute path to the rasa executable.
# Leave blank to auto-detect from your system PATH (recommended).
#
# Windows example:
#   RASA_EXE=C:\Users\YourName\AppData\Local\Programs\Python\Python310\Scripts\rasa.exe
#
# Linux / macOS example:
#   RASA_EXE=/usr/local/bin/rasa
#
# Leave empty if `rasa` is already on your PATH:
RASA_EXE=
